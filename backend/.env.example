ENVIRONMENT=development
DEBUG=true
DATABASE_URL=sqlite:///./astra.db
JWT_SECRET=replace-with-long-random-string
REDIS_URL=redis://localhost:6379/0
COLLAB_WS_URL=ws://localhost:1234
SCHEDULER_GRPC_URL=localhost:50051
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin12345

# electricityMaps — sign up at https://www.electricitymaps.com/free-tier-api
# Sandbox keys only return data for DK-DK1 with "SANDBOX_MODE_DATA" flag.
# Free production: 1000 req/month, real-time, all zones.
ELECTRICITY_MAPS_TOKEN=
ELECTRICITY_MAPS_ZONE=DK-DK1
ELECTRICITY_MAPS_URL=https://api.electricitymap.org/v3
