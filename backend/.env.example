ENVIRONMENT=development
DEBUG=true
DATABASE_URL=sqlite:///./astra.db
JWT_SECRET=replace-with-long-random-string
REDIS_URL=redis://localhost:6379/0
COLLAB_WS_URL=ws://localhost:1234
SCHEDULER_GRPC_URL=localhost:50051
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin12345

# electricityMaps — sign up at https://www.electricitymaps.com/free-tier-api
# Sandbox keys only return data for DK-DK1 with "SANDBOX_MODE_DATA" flag.
# Free production: 1000 req/month, real-time, all zones.
ELECTRICITY_MAPS_TOKEN=
ELECTRICITY_MAPS_ZONE=DK-DK1
ELECTRICITY_MAPS_URL=https://api.electricitymap.org/v3

# Google "Sign in with Google" — see docs/OAUTH-SETUP.md for step-by-step.
# Create an OAuth 2.0 Client ID (type: Web application) in Google Cloud Console,
# register redirect URI http://localhost:3000/api/auth/google/callback, then
# paste the values below. Leave blank to keep Google sign-in disabled.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
FRONTEND_URL=http://localhost:3000

# GitHub OAuth App — https://github.com/settings/developers > New OAuth App
# Homepage URL: http://localhost:3000
# Authorization callback URL: http://localhost:3000/api/auth/github/callback
# Scopes granted: read:user user:email repo (full private repo read/write)
# Leave blank to keep GitHub sign-in disabled.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/api/auth/github/callback
# Fernet key to encrypt stored GitHub tokens (generate once, never rotate without migration):
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GITHUB_TOKEN_ENCRYPTION_KEY=
